/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership security model. All data created
 * by a user is considered private and is only accessible by that user. It achieves
 * this by structurally segregating all user-specific data under a path that
 * includes their unique user ID.
 *
 * Data Structure:
 * The data is organized into a top-level `/users/{userId}` collection, under which
 * all private subcollections like `rentedGenerators` are nested. There are also
 * separate top-level collections for transaction requests that admins will manage.
 *
 * Key Security Decisions:
 * - User Isolation: A user's access is strictly confined to documents within their
 *   own data tree (i.e., `/users/{their-own-userId}/...`).
 * - No User Discovery: Listing the top-level `/users` collection is explicitly
 *   disallowed to prevent users from discovering each other.
 * - Default Deny: Any access not explicitly granted is denied.
 *
 * Denormalization for Authorization:
 * To ensure fast and secure authorization, user-specific documents contain a `userId` field.
 * On creation, this field is validated to match the authenticated user's ID. On update,
 * this field is made immutable. This prevents documents from being moved between users and
 * simplifies security rules by avoiding costly cross-document `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingDoc() {
      return resource != null;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    // --------------------------------
    // User Data
    // --------------------------------
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    match /users/{userId}/rentedGenerators/{rentedGeneratorId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }
    
    // --------------------------------
    // Transaction Requests (Admin Managed)
    // --------------------------------
    match /depositRequests/{requestId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read, update, delete, list: if false; // Only admins can manage
    }

    match /withdrawalRequests/{requestId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read, update, delete, list: if false; // Only admins can manage
    }
  }
}
