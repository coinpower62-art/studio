{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the CoinPower application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "username": {
          "type": "string",
          "description": "The user's unique username."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's unique email address, used for login and notifications.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The user's optional phone number."
        },
        "preferredLanguageCode": {
          "type": "string",
          "description": "The ISO 639-1 language code (e.g., 'en', 'it') representing the user's preferred language for the application UI."
        },
        "country": {
          "type": "string",
          "description": "The country where the user resides."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the user account was last updated.",
          "format": "date-time"
        },
        "balance": {
          "type": "number",
          "description": "The user's current account balance."
        },
        "referralCode": {
          "type": "string",
          "description": "The user's unique referral code."
        },
        "referralCount": {
          "type": "number",
          "description": "The number of users referred by this user."
        },
        "referredBy": {
          "type": "string",
          "description": "The referral code of the user who referred this user, if any."
        },
        "avatar": {
          "type": "string",
          "description": "URL of the user's avatar image."
        },
        "hasWithdrawalPin": {
          "type": "boolean",
          "description": "Indicates if the user has set up a withdrawal PIN."
        }
      },
      "required": [
        "id",
        "username",
        "fullName",
        "email",
        "country",
        "createdAt",
        "updatedAt"
      ]
    },
    "RentedGenerator": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RentedGenerator",
      "type": "object",
      "description": "Represents a generator rented by a user.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference to the User who owns this rented generator."
        },
        "generatorId": {
          "type": "string",
          "description": "The ID of the generator template."
        },
        "name": {
          "type": "string",
          "description": "The name of the generator."
        },
        "rentalTime": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the generator was rented."
        },
        "rentalEndTime": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the current earning cycle ends."
        },
        "durationDays": {
          "type": "number",
          "description": "The total duration of the rental in days."
        },
        "dailyIncome": {
          "type": "number",
          "description": "The income generated per day by this generator."
        },
        "icon": {
          "type": "string",
          "description": "The icon representing the generator."
        },
        "color": {
          "type": "string",
          "description": "The color theme of the generator."
        },
        "price": {
          "type": "number",
          "description": "The rental price of the generator."
        }
      },
      "required": [
        "userId",
        "generatorId",
        "name",
        "rentalTime",
        "rentalEndTime",
        "durationDays",
        "dailyIncome",
        "icon",
        "color",
        "price"
      ]
    },
    "DepositRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DepositRequest",
      "type": "object",
      "description": "Represents a user's request to deposit funds, pending admin approval.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "amount": { "type": "number" },
        "txId": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "default": "pending" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "fullName", "amount", "txId", "date", "status", "createdAt"]
    },
    "WithdrawalRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WithdrawalRequest",
      "type": "object",
      "description": "Represents a user's request to withdraw funds, pending admin approval.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "fullName": { "type": "string" },
        "country": { "type": "string" },
        "method": { "type": "string" },
        "amount": { "type": "number" },
        "netAmount": { "type": "number" },
        "fee": { "type": "number" },
        "details": { "type": "string" },
        "status": { "type": "string", "default": "pending" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "fullName", "country", "method", "amount", "netAmount", "fee", "details", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/users/{userId}/rentedGenerators/{rentedGeneratorId}",
        "definition": {
          "entityName": "RentedGenerator",
          "schema": {
            "$ref": "#/backend/entities/RentedGenerator"
          },
          "description": "Stores generators rented by a specific user."
        }
      },
      {
        "path": "/users/{userId}/depositRequests/{depositRequestId}",
        "definition": {
            "entityName": "DepositRequest",
            "schema": {
                "$ref": "#/backend/entities/DepositRequest"
            },
            "description": "Stores a specific user's deposit requests. Admins can review all requests across users."
        }
      },
      {
        "path": "/users/{userId}/withdrawalRequests/{withdrawalRequestId}",
        "definition": {
            "entityName": "WithdrawalRequest",
            "schema": {
                "$ref": "#/backend/entities/WithdrawalRequest"
            },
            "description": "Stores a specific user's withdrawal requests. Admins can review all requests across users."
        }
      }
    ]
  }
}